      "id": 7,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "100 * max(vllm:kv_cache_usage_perc)",
          "legendFormat": "used %",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "100 * (1 - max(vllm:kv_cache_usage_perc))",
          "legendFormat": "free %",
          "refId": "B"
        }
      ],
      "title": "KV cache headroom",
      "type": "timeseries"
