# Copy to .env and fill in.

# HuggingFace token for model downloads.
HF_TOKEN=

# The model id you actually serve. Must match whatever you pass to vLLM
# via scripts/start_vllm.sh - if you serve an FP8 / AWQ / GPTQ variant,
# the model id here changes accordingly. The agent uses this for its
# chat-completions requests.
VLLM_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507

# Optional: point the agent at any OpenAI-compatible API so you can build and
# debug the Phase 3 graph without a running vLLM. Uncomment and fill in, then
# switch back to the defaults for final prompt tuning and all of Phases 5-6.
# VLLM_BASE_URL=https://api.openai.com/v1
# VLLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...

# Langfuse keys - you'll get these in Phase 4 after creating a project
# in the local Langfuse UI at http://localhost:3001.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3001

# Agent quality/latency knobs.
AGENT_FAST_PATH=false
AGENT_MAX_WORKERS=128
AGENT_MAX_INFLIGHT=128
AGENT_QUEUE_TIMEOUT_SECONDS=0.25
AGENT_MAX_TOKENS=256
AGENT_SCHEMA_MAX_CHARS=12000
AGENT_SQL_MAX_ROWS=100
AGENT_CONDITIONAL_VERIFY=true
AGENT_SEMANTIC_LLM_VERIFY=false
AGENT_MAX_ITERATIONS=3
AGENT_MAX_REVISIONS=1
AGENT_VERIFY_SCHEMA_MAX_CHARS=3000
AGENT_VERIFY_MANY_ROWS_THRESHOLD=80
AGENT_SCHEMA_TOP_TABLES=8
AGENT_VALUE_HINT_MAX_COLUMNS=12
AGENT_VALUE_HINT_MAX_VALUES=8
AGENT_SINGLEFLIGHT=true
AGENT_ADAPTIVE_PRESSURE=true
AGENT_DETERMINISTIC_ONLY_AT=24
AGENT_PRESSURE_FAST_PATH_AT=48

# Optional: use a smaller/faster OpenAI-compatible model for verification.
# Defaults to VLLM_BASE_URL / VLLM_MODEL when unset.
# AGENT_VERIFIER_BASE_URL=https://api.openai.com/v1
# AGENT_VERIFIER_MODEL=gpt-4o-mini
# AGENT_VERIFIER_API_KEY=sk-...
# AGENT_VERIFIER_MAX_TOKENS=96
